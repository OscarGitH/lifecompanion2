{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"noAutofocus": "warn"
			},
			"suspicious": {
				"noConsole": "warn"
			}
		}
	},
	"assist": {
		"enabled": true
	},
	"html": {
		"experimentalFullSupportEnabled": true,
		"parser": {
			"interpolation": true
		},
		"formatter": {
			"enabled": true
		}
	}
}
