{
	"name": "@lifecompanionaac/lifecompanion",
	"description": "LifeCompanion apps",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"check-types": "vue-tsc --noEmit",
		"player:dev": "vite --config vite.player.config.ts",
		"player:build": "vue-tsc --noEmit && vite build --config vite.player.config.ts",
		"player:preview": "vite preview --config vite.player.config.ts",
		"editor:dev": "vite --config vite.editor.config.ts",
		"editor:build": "vue-tsc --noEmit && vite build --config vite.editor.config.ts",
		"editor:preview": "vite preview --config vite.editor.config.ts"
	},
	"dependencies": {
		"@lifecompanion/model": "workspace:*",
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-opener": "^2",
		"es-toolkit": "^1.44.0",
		"pinia": "^3.0.4",
		"vue": "^3.5.13",
		"vue-i18n": "^11.2.8",
		"vuetify": "^4.0"
	},
	"devDependencies": {
		"@intlify/unplugin-vue-i18n": "^11.0.3",
		"@mdi/js": "^7.4.47",
		"@tauri-apps/cli": "^2",
		"@types/node": "^25.2.0",
		"@vitejs/plugin-vue": "^5.2.1",
		"chokidar": "^5.0.0",
		"tsx": "^4.21.0",
		"typescript": "~5.6.2",
		"vite": "^6.0.3",
		"vite-plugin-vuetify": "^2.1.3",
		"vue-tsc": "^2.1.10"
	}
}
